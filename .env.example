AGENTIC_SEARCH_BACKEND=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
GENERATION_MODEL=qwen3.5:9b
EMBEDDING_MODEL=bge-m3
# 改端口需同步更新 docker-compose 的 ports 映射与 docker/prometheus/prometheus.yml 的抓取目标 (agentic-search:8080)
AGENTIC_SEARCH_HOST=0.0.0.0
AGENTIC_SEARCH_PORT=8080
GRAFANA_PASSWORD=admin
# 可选:Tavily API key(https://tavily.com 免费注册)。配置后 agent 获得 web_search 工具;
# 留空则纯本地 RAG,全链路离线零 key。
TAVILY_API_KEY=
